{
  "schemaVersion": 1,
  "id": "catskinc-remake",
  "version": "${version}",
  "name": "CatSkinC-Remake",
  "description": "Cloud skin upload and live sync for CatSkinC.",
  "authors": [
    "Q Team Studio"
  ],
  "contact": {
    "homepage": "https://dotpp.xyz"
  },
  "license": "MIT",
  "icon": "assets/catskinc-remake/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.sammy.catskincRemake.fabric.CatskincRemakeFabric"
    ],
    "client": [
      "com.sammy.catskincRemake.fabric.client.CatskincRemakeFabricClient"
    ]
  },
  "mixins": [
    "catskinc-remake.mixins.json"
  ],
  "depends": {
    "fabricloader": "${fabric_loader_version_range}",
    "minecraft": "${minecraft_version_range}",
    "java": "${java_version_range}",
    "architectury": "${architectury_version_range}",
    "fabric-api": "*"
  },
  "suggests": {
    "voicechat": "*",
    "plasmovoice": "*",
    "figura": "*",
    "emotecraft": "*"
  }
}
